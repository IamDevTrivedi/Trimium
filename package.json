{
    "name": "trimium",
    "version": "0.1.0",
    "description": "Monorepo for Trimium, a full-stack URL shortener, QR generator, and analytics platform.",
    "type": "module",
    "scripts": {
        "format": "prettier --write \"**/*.{js,ts,tsx,json,css}\"",
        "format:check": "prettier --check \"**/*.{js,ts,tsx,json,css}\"",
        "lint": "eslint . --ext .js,.ts,.tsx",
        "lint:fix": "eslint . --ext .js,.ts,.tsx --fix",
        "check": "pnpm lint && pnpm format:check",
        "prepare": "husky",
        "install:all": "node ./scripts/install-all.js",
        "clean:all": "node ./scripts/clean-all.js",
        "reset:all": "node ./scripts/reset-all.js",
        "dev": "concurrently -n CLIENT,SERVER -c cyan,green \"pnpm --filter client dev\" \"pnpm --filter server dev\"",
        "download:geoip": "node ./scripts/update-geolite2.js"
    },
    "keywords": [],
    "author": "Dev Trivedi <devtrivedi.work@gmail.com> (https://github.com/IamDevTrivedi)",
    "github": "https://github.com/IamDevTrivedi/Trimium",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IamDevTrivedi/Trimium.git"
    },
    "bugs": {
        "url": "https://github.com/IamDevTrivedi/Trimium/issues"
    },
    "homepage": "https://github.com/IamDevTrivedi/Trimium#readme",
    "license": "MIT",
    "packageManager": "pnpm@10.28.0",
    "dependencies": {
        "prettier": "^3.7.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "concurrently": "^9.2.1",
        "dotenv": "^16.6.1",
        "eslint": "^10.2.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "tar": "^7.5.13",
        "typescript-eslint": "^8.58.0"
    }
}
