printf '%s\n' '[husky][pre-push] Starting quality checks...'
printf '%s\n' '[husky][pre-push] Running: pnpm check'

if pnpm check; then
	printf '%s\n' '[husky][pre-push] All checks passed. Push allowed.'
else
	status=$?
	printf '%s\n' "[husky][pre-push] Checks failed (exit code: $status). Push blocked."
	exit "$status"
fi
