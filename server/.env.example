# Server Configuration
PORT=5000

# Backend URLs
# Development: Use localhost with your server port
BACKEND_URL_DEV=http://localhost:5000
# Production: Replace with your deployed backend URL (e.g., from Render, Railway, Heroku)
BACKEND_URL_PROD=https://your-backend-url.com

# Frontend URLs
# Development: Use localhost with your React/frontend dev server port
FRONTEND_URL_DEV=http://localhost:3000
# Production: Replace with your deployed frontend URL (e.g., from Vercel, Netlify)
FRONTEND_URL_PROD=https://your-frontend-url.com

# MongoDB Configuration
# Local: mongodb://localhost:27017/your-database-name
# Cloud: Get connection string from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
MONGODB_URI=mongodb://localhost:27017/your-database-name

# Redis Configuration
# Get credentials from Redis Cloud (https://redis.com/try-free/) or Upstash (https://upstash.com/)
REDIS_USERNAME=your-redis-username
REDIS_PASSWORD=your-redis-password
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379

# Email Configuration 
# Get API key from Brevo (formerly Sendinblue) Dashboard (https://www.brevo.com/en/dashboard/)
SENDER_EMAIL=your-email@example.com
BREVO_API_KEY=your-brevo-api-key-here

# JWT Secret Key
# Generate a secure random string (minimum 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_KEY=your-very-secure-and-long-jwt-key-goes-here-please-change-it

# Cloudflare Turnstile Configuration
# Secret key from Cloudflare Turnstile dashboard (server-side only)
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key

# Proof of Work Configuration
# PoW Secret Key
# Generate a secure random string (minimum 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).to
PoW_SECRET=your-very-secure-and-long-pow-secret-goes-here-please-change-it
# PoW Difficulty Level (1-4)
PoW_DIFFICULTY=3

# Cloudinary Configuration
# Get credentials from Cloudinary Dashboard (https://cloudinary.com/)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Email Logout Signing Key
EMAIL_LOGOUT_SIGNING_KEY=your-email-logout-signing-key-goes-here-please-change-it

# Instructions:
# 1. Rename this file to .env.development for development environment.
# 2. Create another file named .env.production for production environment with appropriate values.
# 3. The server will only run if the all environment variables are set & with valid values. Please refer to : server\src\config\checkEnv.ts for the list of required variables & their validation.